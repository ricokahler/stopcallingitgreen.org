# Cloudflare Pages direct upload and Terraform/OpenTofu
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional one-time bootstrap token used to create CLOUDFLARE_API_TOKEN by API.
# Needs Account API Tokens Write, usually from Cloudflare's "Create additional tokens" template.
CLOUDFLARE_BOOTSTRAP_API_TOKEN=
CLOUDFLARE_DEPLOY_TOKEN_NAME=stopcallingitgreen-org-deploy
CLOUDFLARE_DEPLOY_TOKEN_EXPIRES_ON=

# Terraform variables can be passed this way if preferred.
TF_VAR_cloudflare_account_id=
TF_VAR_cloudflare_api_token=

# Optional registrar automation for scripts/namecheap-set-nameservers.mjs.
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=
NAMECHEAP_DOMAIN=stopcallingitgreen.org
NAMECHEAP_NAMESERVERS=
