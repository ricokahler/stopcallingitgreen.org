# Cloudflare Pages direct upload and Terraform/OpenTofu
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional one-time bootstrap token used to create the GitHub Actions deploy token.
# Needs permission to create additional Cloudflare API tokens.
CLOUDFLARE_BOOTSTRAP_API_TOKEN=
CLOUDFLARE_DEPLOY_TOKEN_NAME=stopcallingitgreen-org-pages-ci
CLOUDFLARE_DEPLOY_TOKEN_EXPIRES_ON=
GITHUB_REPOSITORY=ricokahler/stopcallingitgreen.org

# Terraform variables can be passed this way if preferred.
TF_VAR_cloudflare_account_id=
TF_VAR_cloudflare_api_token=

# Optional registrar automation for scripts/namecheap-set-nameservers.mjs.
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=
NAMECHEAP_DOMAIN=stopcallingitgreen.org
NAMECHEAP_NAMESERVERS=
