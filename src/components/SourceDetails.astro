---
import type { SourceLink } from "../lib/chapters";

interface Props {
  sources?: SourceLink[];
}

const { sources = [] } = Astro.props;
---

{sources.length > 0 && (
  <details class="source-details">
    <summary>Sources and further reading</summary>
    <ul>
      {sources.map((source) => (
        <li>
          <a href={source.url} rel="noreferrer" target="_blank">
            {source.title}
          </a>
        </li>
      ))}
    </ul>
  </details>
)}
