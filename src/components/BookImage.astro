---
import { Image } from "astro:assets";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption: string;
  creditHref?: string;
  creditLabel?: string;
  wide?: boolean;
  priority?: boolean;
  position?: string;
}

const {
  src,
  alt,
  caption,
  creditHref,
  creditLabel = "Photo source",
  wide = false,
  priority = false,
  position = "center"
} = Astro.props;

const width = wide ? 1440 : 1120;
const widths = wide ? [480, 720, 960, 1200, 1440] : [360, 540, 720, 960, 1120];
const sizes = wide
  ? "(min-width: 1120px) 1040px, calc(100vw - 2rem)"
  : "(min-width: 880px) 70ch, calc(100vw - 2rem)";
---

<figure class:list={["book-image", wide && "book-image-wide"]} style={`--image-position: ${position};`}>
  <div class="book-image-frame">
    <Image
      src={src}
      alt={alt}
      width={width}
      widths={widths}
      layout="constrained"
      format="webp"
      quality={72}
      sizes={sizes}
      loading={priority ? "eager" : "lazy"}
      decoding="async"
      class="book-image-media"
    />
  </div>
  <figcaption>
    <span>{caption}</span>
    {creditHref && (
      <a href={creditHref}>{creditLabel}</a>
    )}
  </figcaption>
</figure>
