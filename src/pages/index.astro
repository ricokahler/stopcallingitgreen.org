---
import { Image } from "astro:assets";
import BookImage from "../components/BookImage.astro";
import BottomCTA from "../components/BottomCTA.astro";
import Layout from "../layouts/Layout.astro";
import { chapters } from "../lib/chapters";
import nasaSunSdo from "../assets/visuals/nasa-sun-sdo.jpg";
import solarFarmFarmland from "../assets/visuals/solar-farm-farmland-unsplash.jpg";

const firstChapter = chapters[0];
---

<Layout bodyClass="home-shell">
  <main class="home-page">
    <section class="home-hero" aria-labelledby="site-title">
      <div class="home-hero-inner">
        <div class="home-hero-copy">
          <p class="kicker">Free online book</p>
          <h1 id="site-title">Stop Calling It Green</h1>
          <p class="subtitle">How Cheap Power Got Dragged Into The Culture War</p>
          <p class="lede">
            Solar is not a virtue product. It is infrastructure. Oil and gas
            look normal because the incumbent energy system won the framing war
            first.
          </p>
          <div class="actions">
            <a class="button primary" href={`/chapters/${firstChapter.slug}/`}>
              Start reading
            </a>
            <a class="button" href="#chapters">Browse chapters</a>
          </div>
        </div>
        <figure class="hero-sun">
          <Image
            src={nasaSunSdo}
            alt="A full disk image of the sun captured by NASA's Solar Dynamics Observatory."
            width={720}
            widths={[320, 480, 640, 720]}
            sizes="(min-width: 900px) 38vw, 72vw"
            format="webp"
            quality={78}
            loading="eager"
            decoding="async"
            class="hero-sun-image"
          />
          <figcaption>NASA/SDO image. The fuel source, not the brand identity.</figcaption>
        </figure>
      </div>
    </section>

    <section class="home-visual" aria-label="Solar and land use scale">
      <BookImage
        src={solarFarmFarmland}
        alt="Aerial view of solar panels installed beside farm fields."
        caption="A solar farm beside cropland makes the land question visible: panels are not a mood, they are another land-use choice."
        creditHref="https://unsplash.com/photos/aerial-view-shows-a-solar-farm-next-to-farmland-5czuT4jlN9s"
        creditLabel="Photo: Aivars Vilks / Unsplash"
        wide
      />
    </section>

    <section class="premise-band" aria-labelledby="premise-title">
      <h2 id="premise-title">The premise is deliberately plain.</h2>
      <div class="premise-copy">
        <p>
          A panel in a field does not need a train full of coal, a tanker full
          of oil, a refinery, a pipeline, a drilling lease, a fuel contract, or
          a protected shipping lane. Sunlight hits it. Electrons move.
          Electricity comes out.
        </p>
        <p>
          The argument here is not that every solar project is good, or that
          every other source is evil. It is that Americans should stop letting
          old energy call itself reality while cheap fuel-free power gets
          treated like a personality test.
        </p>
      </div>
    </section>

    <section class="chapters-section" id="chapters" aria-labelledby="chapters-title">
      <header>
        <h2 id="chapters-title">Read the book.</h2>
        <p>
          Each chapter is built for online reading, with sources and videos
          close to the claims they support.
        </p>
      </header>
      <ol class="chapter-list">
        {chapters.map((chapter) => (
          <li>
            <a href={`/chapters/${chapter.slug}/`}>
              <span>{chapter.chapterLabel}</span>
              <div>
                <strong>{chapter.title}</strong>
                <p>{chapter.description}</p>
              </div>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <section class="about-note" aria-labelledby="online-title">
      <h2 id="online-title">Online-only, on purpose.</h2>
      <div>
        <p>
          This is the only place this book exists: self-funded, free, public,
          and built to be inspected. No donation page, no merch table, no
          organization waiting behind it.
        </p>
        <p><a href="/about/">About the project</a></p>
      </div>
    </section>

    <BottomCTA
      title="Read it straight through."
      body="It is short on purpose. Start at the beginning, or jump to the part that already sounds like the argument you keep hearing."
      primaryHref={`/chapters/${firstChapter.slug}/`}
      primaryLabel="Start reading"
      secondaryHref="#chapters"
      secondaryLabel="Browse chapters"
    />
  </main>
</Layout>
