---
import BottomCTA from "../../components/BottomCTA.astro";
import ChapterNav from "../../components/ChapterNav.astro";
import SourceDetails from "../../components/SourceDetails.astro";
import Layout from "../../layouts/Layout.astro";
import { chapters, getAdjacentChapters, type ChapterMeta } from "../../lib/chapters";

export function getStaticPaths() {
  return chapters.map((chapter) => ({
    params: { slug: chapter.slug },
    props: { chapter }
  }));
}

interface Props {
  chapter: ChapterMeta;
}

const { chapter } = Astro.props;
const { previous, next } = getAdjacentChapters(chapter.slug);
const Content = chapter.Content;
---

<Layout title={chapter.title} description={chapter.description}>
  <main class="reader-shell">
    <header class="chapter-header">
      <p class="chapter-meta">{chapter.chapterLabel}</p>
      <h1>{chapter.title}</h1>
      <p>{chapter.description}</p>
    </header>
    <article class="prose">
      <Content />
    </article>
    <SourceDetails sources={chapter.sources} />
    <ChapterNav previous={previous} next={next} />
    {chapter.slug === "conclusion" && (
      <BottomCTA
        title="What now?"
        body="Keep the useful skepticism. Vote for wires, storage, local power, and less fuel dependence. Share the argument when it comes up naturally."
        primaryHref="/chapters/introduction/"
        primaryLabel="Read from the start"
        secondaryHref="/about/"
        secondaryLabel="About the project"
      />
    )}
  </main>
</Layout>
